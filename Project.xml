<?xml version="1.0" encoding="utf-8"?>
<project>
	<!-- _________________________ Application Settings _________________________ -->

	<app title="FNF: Psych Engine" file="PsychEngine"
		packageName="com.shadowmario.psychengine"
		package="com.shadowmario.psychengine"
		main="Main" version="0.2.8" company="ShadowMario" />

	<set name="APP_ID" value="0x0100f6c013bbc000" />

	<!-- NOTE TO SELF: DISABLE THIS IF ISSUES ARE FOUND -->
	<haxedef name="LINC_LUA_RELATIVE_DYNAMIC_LIB"/>

	<app preloader="flixel.system.FlxPreloader" />
	<set name="SWF_VERSION" value="11.8" />

	<!-- ______________________ PSYCH ENGINE CUSTOMIZATION ______________________ -->

	<define name="MODS_ALLOWED" if="desktop || android" />
	<define name="HSCRIPT_ALLOWED" if="desktop" />
	<define name="LUA_ALLOWED" if="desktop" />
	<define name="ACHIEVEMENTS_ALLOWED" />
	<define name="DISCORD_ALLOWED" if="desktop" />
	<define name="TRANSLATIONS_ALLOWED" />
	<define name="IRIS_DEBUG"/>

	<define name="MULTITHREADED_LOADING" />
	<define name="SHOW_LOADING_SCREEN" />
	<define name="PSYCH_WATERMARKS"/>

	<!-- ========================= MOBILE SUPPORT ========================= -->
	<define name="MOBILE_DATA"    if="mobile" />
	<define name="TOUCH_CONTROLS" if="mobile" />
	<!-- ==================================================================== -->

	<section if="officialBuild">
		<define name="TITLE_SCREEN_EASTER_EGG"/>
		<define name="BASE_GAME_FILES" />
		<define name="VIDEOS_ALLOWED" if="windows || linux || android || mac" unless="32bits"/>
	</section>

	<!-- ____________________________ Window Settings ___________________________ -->

	<window width="1280" height="720" fps="60" background="#000000" hardware="true" vsync="false" allow-high-dpi="true" />
	<window if="html5"   resizable="true" />
	<window if="desktop" orientation="landscape" fullscreen="false" resizable="true" vsync="false"/>
	<window if="mobile"  orientation="landscape" fullscreen="true" width="0" height="0"
	        resizable="false" allow-shaders="true" require-shaders="true" allow-high-dpi="true" />
	<window if="switch"  orientation="landscape" fullscreen="true" width="0" height="0" resizable="true" />

	<!-- ====================== Android SDK moderno ==========================
		targetSdkVersion 34  → Android 14 (exigido pela Play Store desde ago/2024)
		minSdkVersion    21  → Android 5.0 (cobre >99% dos aparelhos ativos)
		compileSdkVersion 34 → necessário para usar APIs do targetSdk 34
	====================================================================== -->
	<section if="android">
		<set name="ANDROID_TARGET_SDK_VERSION" value="34" />
		<set name="ANDROID_MIN_SDK_VERSION"    value="21" />
		<set name="ANDROID_BUILD_SDK_VERSION"  value="34" />
	</section>

	<!-- ====================== Permissões Android ============================
		READ/WRITE_EXTERNAL_STORAGE  → mods no external storage (Android ≤ 12)
		READ_MEDIA_*                 → substitui READ_EXTERNAL no Android 13+
		INTERNET                    → Discord RPC / check for updates
		VIBRATE                     → feedback tátil nos controles touch
	====================================================================== -->
	<section if="android">
		<dependency name="READ_EXTERNAL_STORAGE"
		            value="android.permission.READ_EXTERNAL_STORAGE"  if="MODS_ALLOWED" />
		<dependency name="WRITE_EXTERNAL_STORAGE"
		            value="android.permission.WRITE_EXTERNAL_STORAGE" if="MODS_ALLOWED" />
		<dependency name="READ_MEDIA_IMAGES"
		            value="android.permission.READ_MEDIA_IMAGES"      if="MODS_ALLOWED" />
		<dependency name="READ_MEDIA_AUDIO"
		            value="android.permission.READ_MEDIA_AUDIO"       if="MODS_ALLOWED" />
		<dependency name="READ_MEDIA_VIDEO"
		            value="android.permission.READ_MEDIA_VIDEO"       if="MODS_ALLOWED" />
		<dependency name="INTERNET" value="android.permission.INTERNET" />
		<dependency name="VIBRATE"  value="android.permission.VIBRATE"  />
	</section>

	<!-- ====================== Assinatura / Keystore ==========================
		Assinar com keystore próprio elimina o aviso "App pode conter vírus"
		e é obrigatório para publicar na Google Play Store.

		━━━ GERAR O KEYSTORE (faça UMA vez, guarde o .jks em segurança) ━━━
		  keytool -genkey -v \
		    -keystore psych-engine-release.jks \
		    -alias psychengine \
		    -keyalg RSA -keysize 2048 -validity 10000 \
		    -storepass SUA_SENHA -keypass SUA_SENHA \
		    -dname "CN=ShadowMario,OU=PsychEngine,O=PsychEngine,L=BR,S=SP,C=BR"

		━━━ GITHUB ACTIONS ━━━
		1. Converta:  base64 -w 0 psych-engine-release.jks > keystore.b64
		2. Adicione 4 Secrets no repositório (Settings → Secrets → Actions):
		     KEYSTORE_B64      → conteúdo do keystore.b64
		     KEYSTORE_PASSWORD → sua senha
		     KEY_ALIAS         → psychengine
		     KEY_PASSWORD      → sua senha
		3. No workflow, antes do lime build:
		     - name: Decode keystore
		       run: |
		         echo "${{ secrets.KEYSTORE_B64 }}" | base64 -d > psych-engine-release.jks
		         echo "KEYSTORE_PATH=$(pwd)/psych-engine-release.jks" >> $GITHUB_ENV

		O Lime lê as variáveis de ambiente abaixo automaticamente:
	====================================================================== -->
	<section if="android">
		<certificate path="${KEYSTORE_PATH}"
		             password="${KEYSTORE_PASSWORD}"
		             alias="${KEY_ALIAS}"
		             alias-password="${KEY_PASSWORD}"
		             if="KEYSTORE_PATH" />
	</section>

	<!-- _____________________________ Path Settings ____________________________ -->

	<set name="BUILD_DIR" value="export/debug"  if="debug" />
	<set name="BUILD_DIR" value="export/release" unless="debug" />
	<set name="BUILD_DIR" value="export/32bit"   if="32bits" />

	<classpath name="source" />

	<!-- __________________________ Game Assets & Etc. __________________________ -->

	<define name="CRASH_HANDLER" if="desktop release" />

	<assets path="assets/fonts" />
	<assets path="assets/shared"       exclude="*.ogg" if="web"/>
	<assets path="assets/shared"       exclude="*.mp3" unless="web"/>
	<assets path="assets/embed"        exclude="*.ogg" if="web"     embed="true"/>
	<assets path="assets/embed"        exclude="*.mp3" unless="web" embed="true"/>
	<assets path="assets/videos"       if="VIDEOS_ALLOWED"/>
	<assets path="assets/songs"        exclude="*.ogg" if="web"/>
	<assets path="assets/songs"        exclude="*.mp3" unless="web"/>
	<assets path="assets/week_assets"  rename="assets" exclude="*.ogg" if="web"/>
	<assets path="assets/week_assets"  rename="assets" exclude="*.mp3" unless="web"/>

	<section if="TITLE_SCREEN_EASTER_EGG">
		<assets path="assets/secrets" rename="assets/shared" exclude="*.ogg" if="web"/>
		<assets path="assets/secrets" rename="assets/shared" exclude="*.mp3" unless="web"/>
	</section>

	<section if="TRANSLATIONS_ALLOWED">
		<assets path="assets/translations" rename="assets" exclude="*.ogg" if="web"/>
		<assets path="assets/translations" rename="assets" exclude="*.mp3" unless="web"/>
	</section>

	<section if="BASE_GAME_FILES">
		<assets path="assets/base_game" rename="assets" exclude="*.ogg" if="web"/>
		<assets path="assets/base_game" rename="assets" exclude="*.mp3" unless="web"/>
		<haxelib name="grig.audio" if="BASE_GAME_FILES"/>
		<haxelib name="funkin.vis" if="BASE_GAME_FILES"/>
	</section>

	<define name="CHECK_FOR_UPDATES" if="desktop officialBuild"/>

	<!-- Mods desktop: embedded junto ao executável -->
	<section if="MODS_ALLOWED desktop">
		<assets path='example_mods' rename='mods' embed='false' type='template' unless="mac"/>
		<assets path='example_mods' rename='mods' embed='false' if="mac"/>
		<assets path='list.txt' rename='modsList.txt' />
	</section>
	<!-- Mods Android: NÃO embuta no APK — lidos via Paths.storagePath em runtime -->

	<assets path='art/readme.txt' rename='do NOT readme.txt' />

	<section if="desktop">
		<assets path="alsoft.txt" rename="plugins/alsoft.ini"  type="text" if="windows"/>
		<assets path="alsoft.txt" rename="plugins/alsoft.conf" type="text" unless="windows"/>
	</section>

	<!-- _______________________________ Libraries ______________________________ -->

	<haxelib name="flixel"         version="5.6.1"/>
	<haxelib name="flixel-addons"  version="3.2.2"/>
